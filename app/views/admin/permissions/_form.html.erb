<%= form_with(model: [:admin, resource], local: true, data: { turbo: false }, class: "space-y-6") do |form| %>
  <% if resource.errors.any? %>
    <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded relative dark:bg-red-900/20 dark:border-red-800 dark:text-red-300" role="alert">
      <h2 class="font-bold"><%= t("active_admin.permissions.form.errors_title", count: resource.errors.count) %></h2>
      <ul class="list-disc ml-6 mt-2">
        <% resource.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="p-4 rounded-lg bg-gray-50 dark:bg-gray-800">
    <div class="grid grid-cols-1 gap-6 sm:grid-cols-2">
      <div>
        <%= form.label :role_id, t("active_admin.permissions.form.role"), class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
        <%= form.collection_select :role_id,
            Role.global.order(:name),
            :id,
            ->(role) { role.name.titleize },
            { include_blank: t("active_admin.permissions.form.select_role") },
            class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 dark:bg-gray-700 dark:border-gray-600 dark:text-white" %>
      </div>
    </div>
  </div>

  <% access_types = permission_access_types_for_form %>
  <% grant_index = 0 %>
  <% scope_index = 0 %>

  <div class="p-4 rounded-lg bg-gray-50 dark:bg-gray-800">
    <h3 class="text-lg font-medium text-gray-900 dark:text-white mb-4"><%= t("active_admin.permissions.form.authorizations_title") %></h3>

    <div class="md:flex">
      <ul class="flex-column space-y space-y-4 text-sm font-medium text-gray-500 dark:text-gray-400 md:me-4 mb-4 md:mb-0"
          id="permission-access-type-tabs"
          data-tabs-toggle="#permission-access-type-content"
          data-tabs-active-classes="!inline-flex !items-center !px-4 !py-3 !text-white !bg-blue-700 !rounded-lg !active !w-full !dark:bg-blue-600"
          data-tabs-inactive-classes="inline-flex items-center px-4 py-3 rounded-lg hover:text-gray-900 bg-gray-50 hover:bg-gray-100 w-full dark:bg-gray-800 dark:hover:bg-gray-700 dark:hover:text-white"
          role="tablist">
        <% access_types.each_with_index do |access_type, index| %>
          <li role="presentation">
            <button id="access-type-<%= access_type.key %>-tab"
                    data-tabs-target="#access-type-<%= access_type.key %>"
                    type="button"
                    role="tab"
                    aria-controls="access-type-<%= access_type.key %>"
                    aria-selected="<%= index.zero? %>">
              <%= permission_access_type_icon(access_type) %>
              <span><%= t("active_admin.permissions.access_types.#{access_type.key}", default: access_type.name) %></span>
            </button>
          </li>
        <% end %>
      </ul>

      <div class="p-6 bg-gray-50 text-medium text-gray-500 dark:text-gray-400 dark:bg-gray-800 rounded-lg w-full overflow-x-auto"
           id="permission-access-type-content">
        <% access_types.each_with_index do |access_type, index| %>
          <% matrix = PermissionFormMatrix.new(resource, access_type) %>
          <div id="access-type-<%= access_type.key %>"
               role="tabpanel"
               aria-labelledby="access-type-<%= access_type.key %>-tab"
               class="<%= index.positive? ? 'hidden ' : '' %>">
            <% row_groups = matrix.resources? ? matrix.grouped_resource_rows : { nil => matrix.rows } %>
            <% row_groups.each do |menu_parent, rows| %>
              <% if matrix.resources? && menu_parent.present? %>
                <h4 class="text-sm font-semibold uppercase tracking-wide text-gray-700 dark:text-gray-300 mb-3 mt-4 first:mt-0">
                  <%= menu_parent == "(root)" ? t("active_admin.permissions.navigation.root") : menu_parent.humanize %>
                </h4>
              <% end %>

              <table class="w-full text-sm text-left text-gray-500 dark:text-gray-400 mb-6 last:mb-0">
                <thead class="text-xs text-gray-700 uppercase bg-gray-100 dark:bg-gray-700 dark:text-gray-400">
                  <tr>
                    <th scope="col" class="px-4 py-3 sticky left-0 bg-gray-100 dark:bg-gray-700">
                      <%= t("active_admin.permissions.columns.component") %>
                    </th>
                    <% if matrix.resources? %>
                      <th scope="col" class="px-3 py-3 text-center whitespace-nowrap">
                        <%= t("active_admin.permissions.columns.index_scope") %>
                      </th>
                    <% end %>
                    <% matrix.action_columns.each do |action| %>
                      <th scope="col" class="px-3 py-3 text-center whitespace-nowrap">
                        <%= permission_action_column_label(action) %>
                      </th>
                    <% end %>
                  </tr>
                </thead>
                <tbody>
                  <% rows.each do |row| %>
                    <tr class="bg-white border-b dark:bg-gray-800 dark:border-gray-700 hover:bg-gray-50 dark:hover:bg-gray-700/50">
                      <th scope="row" class="px-4 py-3 font-medium text-gray-900 whitespace-nowrap dark:text-white sticky left-0 bg-white dark:bg-gray-800">
                        <%= row[:label] %>
                      </th>
                      <% if matrix.resources? %>
                        <td class="px-3 py-3 text-center">
                          <%= permission_resource_scope_select(form, resource, row[:access_resource], scope_index).tap { scope_index += 1 } %>
                        </td>
                      <% end %>
                      <% matrix.action_columns.each do |action| %>
                        <% authorization = row[:cells][action] %>
                        <td class="px-3 py-3 text-center">
                          <% if authorization %>
                            <%= permission_grant_checkbox(form, resource, authorization, grant_index).tap { grant_index += 1 } %>
                          <% end %>
                        </td>
                      <% end %>
                    </tr>
                  <% end %>
                </tbody>
              </table>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <div class="flex justify-start space-x-4">
    <%= form.submit t("active_admin.permissions.form.submit"), class: "px-4 py-2 text-sm font-medium text-white bg-blue-600 border border-transparent rounded-md shadow-sm hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500" %>
    <%= link_to t("active_admin.permissions.form.cancel"), admin_permissions_path, class: "px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-md shadow-sm hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 dark:bg-gray-700 dark:text-gray-300 dark:border-gray-600 dark:hover:bg-gray-600" %>
  </div>
<% end %>
